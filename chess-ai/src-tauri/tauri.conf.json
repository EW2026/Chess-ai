{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ChessAI",
  "version": "1.0.0",
  "identifier": "com.chessai",

 
  "build": {
    "frontendDist": "../dist"
  },

  "app": {
    "windows": [
      {
        "title": "Chess AI",
        "width": 1200,
        "height": 1000
      }
    ]
  },

  "bundle": {
    "active": true,
    "targets": ["msi"],
    "resources": [
      "resources/run_server/**/*"
    ],
    "icon": [
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  }
}